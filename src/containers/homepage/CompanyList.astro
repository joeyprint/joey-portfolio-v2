---
import CompanyBox from '@/components/CompanyBox.astro';
import Container from '@/components/Container.astro';

const COMPANIES = [
	{ logoUrl: 'assets/company-logo/odds.png', name: 'ODDS Teams' },
	{ logoUrl: 'assets/company-logo/set.png', name: 'The Stock Exchange Thailand' },
	{ logoUrl: 'assets/company-logo/ttb.png', name: 'TMBThanachart Bank' },
	{ logoUrl: 'assets/company-logo/foodbank.png', name: 'Foodbank BKK' },
	{ logoUrl: 'assets/company-logo/uxth.png', name: 'UX Thailand Communities' },
	{ logoUrl: 'assets/company-logo/skooldio.png', name: 'Skooldio Company' },
	{ logoUrl: 'assets/company-logo/atmosph.png', name: 'Atmosph Company' },
	{ logoUrl: 'assets/company-logo/cjworx.png', name: 'CJWORX Company' },
	{ logoUrl: 'assets/company-logo/digital-spirals.png', name: 'Digital Spirals Company' },
	{ logoUrl: 'assets/company-logo/suffix.png', name: 'Suffix Company' }
];
---

<Container className={'mt-12 flex flex-col items-center justify-center md:mt-16'}>
	<p class={'joey_body2_bold uppercase tracking-[50%] text-primary-700 text-center'}>
		Built <br class={'block md:hidden'} />Professional <br class={'block md:hidden'} />Brands
	</p>
	<div class="mt-6 flex flex-wrap items-center justify-center gap-4">
		{
			COMPANIES.map((company) => (
				<div class="flex max-w-[125px] justify-center sm:max-w-[150px] md:max-w-[175px]">
					<img src={company.logoUrl} alt={company.name} class="w-auto" />
				</div>
			))
		}
	</div>
</Container>
