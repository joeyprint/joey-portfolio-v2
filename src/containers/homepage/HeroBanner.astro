---
import { differenceInYears } from 'date-fns';

import Button from '@/components/Button.astro';
import GitHubIcon from '@/components/icons/GitHubIcon.astro';
import LinkedInIcon from '@/components/icons/LinkedInIcon.astro';
import Container from '@/components/Container.astro';
import { cn } from '@/lib/utils';

const startWorkingDate = new Date('12/15/2019');
const currentDate = new Date();

const diffYear = differenceInYears(currentDate, startWorkingDate);
---

<script>
	const githubButton = document.getElementById('hero-github-button');
	const linkedInButton = document.getElementById('hero-linkedin-button');

	const goToGitHub = () => {
		window.open('https://github.com/joeyprint', '_blank');
	};

	const goToLinkedIn = () => {
		window.open('https://www.linkedin.com/in/joeywasin/', '_blank');
	};
	githubButton?.addEventListener('click', () => {
		goToGitHub();
	});

	linkedInButton?.addEventListener('click', () => {
		goToLinkedIn();
	});
</script>

<div class="bg-primary-100 w-full pt-12 pb-16 md:pb-24">
	<Container className="flex flex-col items-center gap-8 md:flex-row">
		<div class="flex flex-1 shrink-0 flex-col gap-6">
			<h1 class="joey_subtitle1">Hi, I'm Joey Wasin</h1>
			<h2 class="joey_heading1 text-primary">Software Engineer & UX Product</h2>
			<p class="joey_body1">
				Product design and web development. I have been working in the development field for {
					diffYear
				} years so far. I specialize in front-end development and UX/UI design. We live by these words
				in everything we develop and every story we tell. The web and applications mustn't be useless
				for an organization.
			</p>
			<div class="flex gap-4">
				<Button id="hero-linkedin-button"
					><span slot="start-icon"><LinkedInIcon /></span>Linked In</Button
				>
				<Button id="hero-github-button" variant="outlined">
					<span slot="start-icon"><GitHubIcon /></span>
					Github
				</Button>
			</div>
		</div>
		<img
			src="/assets/profile/SIT_Joey.png"
			alt="Joey profile image"
			class={cn(
				'flex-1 shrink-0 rounded-xl object-cover md:max-w-[400px] lg:max-w-[584px]',
				'aspect-(--aspect-ratio-1-1) sm:aspect-(--aspect-ratio-16-9) md:aspect-(--aspect-ratio-1-1) lg:aspect-(--aspect-ratio-16-9)'
			)}
		/>
	</Container>
</div>
