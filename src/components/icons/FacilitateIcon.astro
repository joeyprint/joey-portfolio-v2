---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'svg'> {}

const { ...restProps } = Astro.props;
---

<svg
	width="24"
	height="24"
	viewBox="0 0 24 24"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	{...restProps}
>
	<circle
		cx="12"
		cy="4"
		r="2"
		fill="currentColor"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"></circle>
	<circle
		cx="4"
		cy="18"
		r="2"
		fill="currentColor"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"></circle>
	<circle
		cx="20"
		cy="18"
		r="2"
		fill="currentColor"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"></circle>
	<path
		d="M5.5 16.5L10.5 5.5"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"></path>
	<path
		d="M18.5 16.5L13.5 5.5"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"></path>
	<path
		d="M6 18H18"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"></path>
</svg>
