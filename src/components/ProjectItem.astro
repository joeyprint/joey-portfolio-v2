---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
	name: string;
	imageUrl: string;
}

const { name, imageUrl, ...restProps } = Astro.props;
---

<>
	<div
		{...restProps}
		class={`md:hidden flex flex-col justify-start overflow-hidden shadow-card rounded-md ${restProps.class ?? ''}`}
	>
		<img src={imageUrl} alt={`${name} Project`} class={'aspect-(--aspect-ratio-16-9) w-full'} />
		<div class="bg-white p-4">
			<p class="joey_subtitle2_bold">{name}</p>
			<div class="mt-3 flex flex-col">
				<slot name="project-description" />
			</div>
		</div>
	</div>
	<div
		{...restProps}
		class={`hidden md:flex w-full flex-col justify-between items-center overflow-hidden max-h-[360px] bg-primary-100 hover:bg-primary-300/50 pt-4 px-4 md:pt-8 sm:px-8 md:px-12 lg:px-16 ${restProps.class ?? ''}`}
	>
		<div class={'min-h-[120px]'}>
			<p class={'joey_subtitle2_bold text-center'}>{name}</p>
			<div class="mt-3 flex flex-col">
				<slot name="project-description" />
			</div>
		</div>
		<div class={'h-[200px] w-full relative mt-4'}>
			<img
				src={imageUrl}
				alt={`${name} Project`}
				class={'absolute top-0 w-full h-auto shadow-image rounded-sm'}
			/>
		</div>
	</div>
</>
